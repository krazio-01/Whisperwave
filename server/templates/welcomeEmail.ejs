<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Welcome to whisperwave</title>
        <style>
            body {
                margin: 0;
                padding: 0;
                background-color: #f4f4f5;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
                -webkit-font-smoothing: antialiased;
            }
            .wrapper {
                width: 100%;
                table-layout: fixed;
                background-color: #f4f4f5;
                padding: 40px 0;
            }
            .container {
                background-color: #ffffff;
                max-width: 600px;
                margin: 0 auto;
                padding: 16px;
                border-radius: 12px;
            }
            .header {
                padding: 12px 24px;
                margin-bottom: 12px;
            }
            .header-text {
                font-size: 16px;
                font-weight: 700;
                color: #09090b;
                letter-spacing: -0.5px;
            }
            .card {
                background-color: #f4f4f5;
                border-radius: 10px;
                padding: 40px 24px;
                text-align: center;
                margin-bottom: 8px;
            }
            .pre-heading {
                font-size: 13px;
                color: #71717a;
                margin-top: 0;
                margin-bottom: 24px;
            }
            .heading {
                font-size: 36px;
                font-weight: 700;
                color: #09090b;
                margin: 0 0 24px 0;
                letter-spacing: -1px;
                line-height: 1.1;
            }
            .text {
                font-size: 16px;
                color: #52525b;
                line-height: 1.5;
                margin: 0 auto 24px auto;
                max-width: 440px;
            }
            .steps-container {
                text-align: left;
                max-width: 380px;
                margin: 0 auto 32px auto;
                padding: 0;
                list-style: none;
            }
            .step-item {
                font-size: 15px;
                color: #27272a;
                line-height: 1.5;
                margin-bottom: 16px;
                display: table;
            }
            .step-number {
                display: table-cell;
                width: 24px;
                font-weight: 700;
                color: #71717a;
                vertical-align: top;
            }
            .step-text {
                display: table-cell;
                vertical-align: top;
                color: #3f3f46;
            }

            .button {
                display: inline-block;
                background-color: #09090b;
                color: #fafafa !important;
                text-decoration: none;
                padding: 16px 28px;
                border-radius: 8px;
                font-size: 16px;
                font-weight: 500;
            }
            .footer {
                padding: 40px 24px;
                text-align: center;
            }
            .footer-text {
                font-size: 13px;
                color: #a1a1aa;
                line-height: 1.6;
                margin: 0;
            }
            .footer-link {
                color: #71717a;
                text-decoration: none;
            }

            @media only screen and (max-width: 600px) {
                .wrapper {
                    padding: 0 !important;
                    background-color: #ffffff !important;
                }
                .container {
                    padding: 16px 8px !important;
                    border-radius: 0 !important;
                }
                .heading {
                    font-size: 28px !important;
                }
                .card {
                    padding: 32px 16px !important;
                    border-radius: 8px !important;
                }
                .button {
                    width: 100% !important;
                    box-sizing: border-box !important;
                }
                .steps-container {
                    max-width: 100% !important;
                    padding: 0 8px !important;
                }
            }
        </style>
    </head>
    <body>
        <div class="wrapper">
            <div class="container">
                <table width="100%" cellpadding="0" cellspacing="0" border="0" class="header">
                    <tr>
                        <td class="header-text">whisperwave</td>
                    </tr>
                </table>

                <div class="card">
                    <p class="pre-heading">Thanks for joining us</p>
                    <h1 class="heading">Welcome to<br />whisperwave</h1>
                    <p class="text">
                        Hi <strong><%= username %></strong>, we're thrilled to have you as a member of our community.
                        You're all set to dive in.
                    </p>
                </div>

                <div class="card" style="padding: 32px 24px">
                    <h2
                        style="
                            font-size: 24px;
                            font-weight: 600;
                            color: #09090b;
                            margin: 0 0 24px 0;
                            letter-spacing: -0.5px;
                        "
                    >
                        How to get started
                    </h2>

                    <ul class="steps-container">
                        <li class="step-item">
                            <span class="step-number">1.</span>
                            <span class="step-text">Log in to your account using your credentials.</span>
                        </li>
                        <li class="step-item">
                            <span class="step-number">2.</span>
                            <span class="step-text"
                                >Find your friends by searching for their unique <strong>username</strong>.</span
                            >
                        </li>
                        <li class="step-item">
                            <span class="step-number">3.</span>
                            <span class="step-text"
                                >Click on <strong>Start Chatting</strong> to launch your secure conversation
                                instantly.</span
                            >
                        </li>
                    </ul>

                    <a href="<%= process.env.BASE_URL %>" class="button">Open whisperwave</a>
                </div>

                <div class="footer">
                    <p class="footer-text" style="margin-bottom: 24px">
                        Whisperwave is the easiest way to connect.<br />If you need assistance, reach out to our support
                        team.
                    </p>
                    <p class="footer-text" style="font-size: 11px">&copy; <%= year %> whisperwave.<br /></p>
                </div>
            </div>
        </div>
    </body>
</html>
