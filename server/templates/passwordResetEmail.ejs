<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Reset your password</title>
        <style>
            body {
                margin: 0;
                padding: 0;
                background-color: #f4f4f5;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
                -webkit-font-smoothing: antialiased;
            }
            .wrapper {
                width: 100%;
                table-layout: fixed;
                background-color: #f4f4f5;
                padding: 40px 0;
            }
            .container {
                background-color: #ffffff;
                max-width: 600px;
                margin: 0 auto;
                padding: 16px;
                border-radius: 12px;
            }
            .header {
                padding: 12px 24px;
                margin-bottom: 12px;
            }
            .header-text {
                font-size: 16px;
                font-weight: 700;
                color: #09090b;
                letter-spacing: -0.5px;
            }
            .card {
                background-color: #f4f4f5;
                border-radius: 10px;
                padding: 48px 24px;
                text-align: center;
                margin-bottom: 8px;
            }
            .pre-heading {
                font-size: 13px;
                color: #71717a;
                margin-top: 0;
                margin-bottom: 24px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }
            .heading {
                font-size: 32px;
                font-weight: 700;
                color: #09090b;
                margin: 0 0 24px 0;
                letter-spacing: -1px;
                line-height: 1.2;
            }
            .text {
                font-size: 16px;
                color: #52525b;
                line-height: 1.5;
                margin: 0 auto 24px auto;
                max-width: 440px;
            }
            .sub-text {
                font-size: 13px;
                color: #a1a1aa;
                margin-top: 32px;
                line-height: 1.5;
            }
            .btn-container {
                margin: 32px 0;
            }
            .btn {
                background-color: #09090b;
                color: #ffffff !important;
                text-decoration: none;
                padding: 14px 32px;
                border-radius: 8px;
                font-size: 16px;
                font-weight: 600;
                display: inline-block;
                transition: opacity 0.2s ease;
            }
            .btn:hover {
                opacity: 0.9;
            }

            .footer {
                padding: 40px 24px;
                text-align: center;
            }
            .footer-text {
                font-size: 11px;
                color: #a1a1aa;
                line-height: 1.6;
                margin: 0;
            }

            @media only screen and (max-width: 600px) {
                .wrapper {
                    padding: 0 !important;
                    background-color: #ffffff !important;
                }
                .container {
                    padding: 16px 8px !important;
                    border-radius: 0 !important;
                }
                .heading {
                    font-size: 28px !important;
                }
                .card {
                    padding: 32px 16px !important;
                    border-radius: 8px !important;
                }
                .btn {
                    width: 100% !important;
                    box-sizing: border-box;
                }
            }
        </style>
    </head>
    <body>
        <div class="wrapper">
            <div class="container">
                <table width="100%" cellpadding="0" cellspacing="0" border="0" class="header">
                    <tr>
                        <td class="header-text">whisperwave</td>
                    </tr>
                </table>

                <div class="card">
                    <p class="pre-heading">Account Recovery</p>
                    <h1 class="heading">Reset Your Password</h1>
                    <p class="text">
                        Hi <strong><%= username %></strong>, we received a request to reset the password for your
                        whisperwave account. Click the button below to set up a new password.
                    </p>

                    <div class="btn-container">
                        <a href="<%= resetUrl %>" class="btn">Reset Password</a>
                    </div>

                    <p class="sub-text">
                        This link will expire in <strong>15 minutes</strong>.<br />
                        If you did not request a password reset, you can safely ignore this email. Your password will
                        remain unchanged.
                    </p>
                </div>

                <div class="footer">
                    <p class="footer-text">
                        &copy; <%= year %> whisperwave. All rights reserved.<br />
                        Need assistance? Reach out to our support team.
                    </p>
                </div>
            </div>
        </div>
    </body>
</html>
